---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
	title?: string
	description?: string
	canonical?: string
	ogImage?: string
}

const {
	title = 'Jakob Pütz',
	description = 'Jakob Pütz (also known as Jakob Puetz or devjakob) — 17-year-old full-stack developer from Aachen, Germany. Building PFControl and Petal. TypeScript, Next.js, Postgres.',
	canonical = 'https://devjakob.com',
	ogImage = 'https://devjakob.com/assets/avatar.jpg',
} = Astro.props

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Jakob Pütz',
	alternateName: ['Jakob Puetz', 'devjakob', 'dev-banane', 'devbanane', 'jakob dev'],
	url: 'https://devjakob.com',
	image: 'https://devjakob.com/assets/avatar.jpg',
	jobTitle: 'Full-Stack Developer',
	description: 'Full-stack developer from Aachen, Germany. Building PFControl and Petal.',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Aachen',
		addressCountry: 'DE',
	},
	sameAs: [
		'https://github.com/dev-banane',
		'https://x.com/devbanane',
		'https://www.linkedin.com/in/jakobpuetz',
	],
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="author" content="Jakob Pütz" />
		<meta name="robots" content="index, follow" />
		<meta id="theme-color-meta" name="theme-color" content="#ffffff" />

		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="Jakob Pütz" />
		<meta property="og:locale" content="en_US" />

		<meta name="twitter:card" content="summary" />
		<meta name="twitter:site" content="@devbanane" />
		<meta name="twitter:creator" content="@devbanane" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<link rel="canonical" href={canonical} />
		<link rel="me" href="https://github.com/dev-banane" />
		<link rel="me" href="https://x.com/devbanane" />
		<link rel="me" href="https://www.linkedin.com/in/jakobpuetz" />

		<link rel="llms" href="https://devjakob.com/llms.txt" type="text/plain" />
		<meta name="llms" content="https://devjakob.com/llms.txt" />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<title>{title}</title>

		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
			rel="stylesheet"
		/>
		<ClientRouter />
		<script is:inline>
			;(function () {
				var THEME_COLORS = { light: '#ffffff', dark: '#0f0f0f' }
				function applyTheme(theme) {
					document.documentElement.setAttribute('data-theme', theme)
					var meta = document.getElementById('theme-color-meta')
					if (meta) meta.content = THEME_COLORS[theme] || THEME_COLORS.light
				}
				window.__applyTheme = applyTheme
				applyTheme(localStorage.getItem('theme') || 'light')
			})()
		</script>
		<script is:inline>
			document.addEventListener('astro:before-swap', function (e) {
				var theme = document.documentElement.getAttribute('data-theme')
				if (!theme) return
				e.newDocument.documentElement.setAttribute('data-theme', theme)
				var meta = e.newDocument.getElementById('theme-color-meta')
				if (meta) meta.content = theme === 'dark' ? '#0f0f0f' : '#ffffff'
			})
		</script>
	</head>
	<body>
		<slot />

		<script>
			document.addEventListener('astro:page-load', () => {
				const toggle = document.getElementById('theme-toggle')
				if (!toggle) return

				const fresh = toggle.cloneNode(true) as Element
				toggle.replaceWith(fresh)

				function current() {
					return document.documentElement.getAttribute('data-theme') ?? 'light'
				}
				fresh.setAttribute('aria-checked', String(current() === 'dark'))
				fresh.addEventListener('click', () => {
					const next = current() === 'dark' ? 'light' : 'dark'
					localStorage.setItem('theme', next)
					;(window as Window & { __applyTheme?: (theme: string) => void }).__applyTheme?.(
						next
					)
					fresh.setAttribute('aria-checked', String(next === 'dark'))
				})
			})
		</script>
	</body>
</html>

<style is:global>
	.theme-toggle {
		border: none;
		background: none;
		padding: 0;
		cursor: pointer;
		flex-shrink: 0;
	}

	.theme-toggle__track {
		--toggle-width: 3.25rem;
		--knob-size: 1.3rem;
		--knob-inset: 0.2rem;
		--knob-travel: 1.5rem;
		position: relative;
		display: block;
		width: var(--toggle-width);
		height: 1.75rem;
		border-radius: 9999px;
		border: 1px solid var(--border);
		background: var(--btn-social-bg);
		transition:
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.theme-toggle__icon {
		position: absolute;
		top: 50%;
		width: 13px;
		height: 13px;
		color: var(--fg-dim);
		transform: translate(-50%, -50%);
		z-index: 3;
		pointer-events: none;
	}

	.theme-toggle__icon.icon-sun {
		left: calc(var(--knob-inset) + var(--knob-size) / 2);
	}

	.theme-toggle__icon.icon-moon {
		left: calc(var(--knob-inset) + var(--knob-travel) + var(--knob-size) / 2);
	}

	[data-theme='light'] .theme-toggle__icon.icon-sun,
	[data-theme='dark'] .theme-toggle__icon.icon-moon {
		color: var(--bg);
	}

	.theme-toggle__knob {
		position: absolute;
		top: 50%;
		left: var(--knob-inset);
		width: var(--knob-size);
		height: var(--knob-size);
		border-radius: 9999px;
		background: var(--fg);
		transform: translateY(-50%);
		transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 2;
	}

	[data-theme='dark'] .theme-toggle__knob {
		transform: translate(calc(var(--knob-travel)), -50%);
	}
</style>
