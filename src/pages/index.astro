---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import Comments from '../components/Comments.astro'
import ThemeToggle from '../components/ThemeToggle.astro'
import { socials } from '../data/site'
import { fetchPostList } from '../lib/posts'
import { env } from 'cloudflare:workers'

const posts = await fetchPostList(env.MEDIA)

Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300')

function formatDate(iso: string) {
	return new Date(iso).toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	})
}
---

<Layout
	title="Jakob Pütz"
	description="Jakob Pütz (Jakob Puetz, devjakob) — 17-year-old full-stack developer from Aachen, Germany. Building PFControl and Petal. TypeScript, Next.js, Postgres."
>
	<div class="page">
		<div class="grid">
			<article class="about">
				<div class="name-row">
					<div>
						<h1 class="name">Jakob Pütz</h1>
						<p class="role">Full-stack developer · Aachen, Germany</p>
					</div>
					<img
						src="/assets/avatar.jpg"
						alt="Jakob Pütz"
						class="profile-avatar"
						width="52"
						height="52"
					/>
				</div>

				<div class="prose">
					<p>
						Hey, I'm a 17-year-old developer. I've been building software since my early
						teens, and what started as curiosity quickly turned into a serious passion
						for making things people actually use.
					</p>
					<p>
						Right now I'm building <a
							href="https://github.com/cephie-studios/pfcontrol-2"
							target="_blank"
							rel="noopener"
							class="link">PFControl</a
						>, an ATC strip management platform I've been working on since I was 15 with
						thousands of registered users and ~500 daily actives, and <a
							href="/posts/petal"
							class="link">Petal</a
						>, a unified AI workspace I'm developing from the ground up.
					</p>
					<p>
						I work across the full stack with TypeScript, Next.js, Postgres, and
						whatever else the problem needs. Outside of code I'm interested in aviation,
						space as well as photography. <a href="#" class="link" id="contact-link"
							>Feel free to contact me!</a
						>
					</p>
				</div>

				<div class="socials">
					{
						socials.map((s) => (
							<a
								href={s.href}
								target="_blank"
								rel="noopener noreferrer me"
								class="btn btn--social"
							>
								<img
									src={s.icon}
									alt={s.label}
									width={28}
									height={28}
									class="btn-icon"
								/>
								{s.label}
							</a>
						))
					}
				</div>

				<address class="sr-only" aria-hidden="true">
					Jakob Pütz, also known as Jakob Puetz, devjakob, and dev-banane — web developer
					based in Aachen, Germany.
				</address>
			</article>

			<aside class="writing">
				<div class="writing-header">
					<h2 class="section-label">Writing</h2>
					<ThemeToggle />
				</div>
				{
					posts.length === 0 ? (
						<p class="empty">Nothing published yet.</p>
					) : (
						<div class="post-scroll-wrap" id="post-scroll-wrap">
							<ul class="post-list" id="post-scroll" data-count={posts.length}>
								{posts.map((p) => (
									<li>
										<a href={`/posts/${p.slug}`} class="post-link">
											<span class="post-title">{p.title}</span>
											<span class="post-date">{formatDate(p.date)}</span>
										</a>
									</li>
								))}
							</ul>
						</div>
					)
				}

				<Comments slug="" />
			</aside>
		</div>
	</div>
</Layout>

<style>
	.page {
		min-height: 100vh;
		padding: 4rem 1.5rem;
	}

	.grid {
		width: 100%;
		max-width: 64rem;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3.5rem;
	}

	@media (min-width: 820px) {
		.grid {
			grid-template-columns: 1.3fr 1fr;
			gap: 5rem;
			align-items: start;
		}
	}

	.about {
		width: 100%;
	}

	.name-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	.profile-avatar {
		width: 3.25rem;
		height: 3.25rem;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		display: block;
	}

	.name {
		font-size: 1.75rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--fg);
	}

	.role {
		font-size: 0.9375rem;
		color: var(--fg-muted);
		margin-top: 0.4rem;
	}

	.prose {
		margin-top: 1.75rem;
		display: flex;
		flex-direction: column;
		gap: 1.1rem;
	}

	.prose p {
		font-size: 1.0625rem;
		line-height: 1.7;
		color: var(--fg-muted);
		text-align: justify;
		hyphens: auto;
	}

	.link {
		color: var(--fg);
		text-decoration: underline;
		text-underline-offset: 3px;
		text-decoration-color: var(--fg-dim);
	}

	.link:hover {
		text-decoration-color: var(--fg);
	}

	.socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.625rem;
		margin-top: 2rem;
	}

	.writing {
		padding-top: 0;
	}

	.writing-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.25rem;
	}

	.post-scroll-wrap {
		margin-bottom: 0.25rem;
	}

	.post-list {
		--fade: 3.5rem;
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent,
			black var(--fade),
			black calc(100% - var(--fade)),
			transparent
		);
		mask-image: linear-gradient(
			to bottom,
			transparent,
			black var(--fade),
			black calc(100% - var(--fade)),
			transparent
		);
	}

	.post-list.no-fade-top {
		-webkit-mask-image: linear-gradient(
			to bottom,
			black,
			black calc(100% - var(--fade)),
			transparent
		);
		mask-image: linear-gradient(
			to bottom,
			black,
			black calc(100% - var(--fade)),
			transparent
		);
	}

	.post-list.no-fade-bottom {
		-webkit-mask-image: linear-gradient(
			to bottom,
			transparent,
			black var(--fade),
			black
		);
		mask-image: linear-gradient(
			to bottom,
			transparent,
			black var(--fade),
			black
		);
	}

	.post-list.no-fade-top.no-fade-bottom {
		-webkit-mask-image: none;
		mask-image: none;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		max-height: 15.5rem;
		overflow-y: auto;
		scrollbar-width: none;
	}

	.post-list::-webkit-scrollbar {
		display: none;
	}

	.post-link {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.9rem 0;
		border-top: 1px solid var(--border);
		transition: opacity 0.15s ease;
	}

	.post-list li:last-child .post-link {
		border-bottom: 1px solid var(--border);
	}

	.post-link:hover {
		opacity: 0.65;
	}

	.post-title {
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--fg);
	}

	.post-date {
		font-size: 0.8125rem;
		color: var(--fg-dim);
		font-variant-numeric: tabular-nums;
	}

	.empty {
		font-size: 0.9rem;
		color: var(--fg-dim);
	}
</style>

<script>
	let cleanups: Array<() => void> = []
	let layoutGen = 0

	function afterTransition(fn: () => void) {
		requestAnimationFrame(() => requestAnimationFrame(fn))
	}

	function initContactLink() {
		const link = document.getElementById('contact-link') as HTMLAnchorElement | null
		if (link) {
			const user = 'me'
			const domain = 'devjakob.com'
			link.href = `mailto:${user}@${domain}`
		}
	}

	function initWriting() {
		cleanups.forEach((fn) => fn())
		cleanups = []
		const gen = ++layoutGen

		const wrap = document.getElementById('post-scroll-wrap')
		const list = document.getElementById('post-scroll')
		const count = Number(list?.dataset.count ?? 0)

		if (list && count >= 4) {
			const syncMask = () => {
				const { scrollTop, scrollHeight, clientHeight } = list
				const atTop = scrollTop <= 2
				const atBottom = scrollTop + clientHeight >= scrollHeight - 2
				list.classList.toggle('no-fade-top', atTop)
				list.classList.toggle('no-fade-bottom', atBottom)
			}
			afterTransition(() => {
				if (gen !== layoutGen) return
				syncMask()
			})
			list.addEventListener('scroll', syncMask, { passive: true })
			cleanups.push(() => list.removeEventListener('scroll', syncMask))
		}

		const syncColumnOffset = () => {
			const page = document.querySelector<HTMLElement>('.page')
			const about = document.querySelector<HTMLElement>('.about')
			const writing = document.querySelector<HTMLElement>('.writing')
			if (!page || !about || !writing) return

			if (window.innerWidth < 820) {
				about.style.paddingTop = ''
				writing.style.paddingTop = ''
				return
			}

			const style = getComputedStyle(page)
			const padY = parseFloat(style.paddingTop) + parseFloat(style.paddingBottom)
			const rail = window.innerHeight - padY
			const offset = Math.max(0, (rail - about.offsetHeight) / 2)
			const top = `${offset}px`
			about.style.paddingTop = top
			writing.style.paddingTop = top
		}

		afterTransition(() => {
			if (gen !== layoutGen) return
			syncColumnOffset()
			window.addEventListener('resize', syncColumnOffset, { passive: true })
			cleanups.push(() => window.removeEventListener('resize', syncColumnOffset))

			const aboutEl = document.querySelector('.about')
			const writingEl = document.querySelector('.writing')
			if (aboutEl && writingEl && 'ResizeObserver' in window) {
				const ro = new ResizeObserver(syncColumnOffset)
				ro.observe(aboutEl)
				ro.observe(writingEl)
				cleanups.push(() => ro.disconnect())
			}
		})
	}

	function init() {
		initContactLink()
		initWriting()
	}

	document.addEventListener('astro:page-load', init)
</script>
