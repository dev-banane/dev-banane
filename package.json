{
	"name": "dev-banane",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vue-tsc -b && vite build",
		"preview": "vite preview",
		"start": "node server/index.js",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"typecheck": "vue-tsc -b --noEmit",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts,vue}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{css,html,md,json,yml,yaml}": "prettier --write"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.13",
		"express": "^5.2.1",
		"lenis": "^1.3.23",
		"lucide-vue-next": "^0.544.0",
		"tailwindcss": "^4.1.13",
		"vue": "^3.5.21",
		"vue-router": "^4.5.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@vitejs/plugin-vue": "^6.0.1",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"@vue/tsconfig": "^0.8.1",
		"eslint": "^10.3.0",
		"eslint-plugin-vue": "^10.9.1",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.3",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^7.1.6",
		"vue-tsc": "^3.0.7"
	}
}
